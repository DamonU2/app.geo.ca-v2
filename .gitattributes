* text=auto

# Source files
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.svelte text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf

# Data and configs
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sh text eol=lf

# Keep Windows scripts on CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf