# Copy this file to .env.<stage> (for local dev use .env.dev)
# Example: cp .env.example .env.dev

# OIDC / Sign-in Configuration
OIDC_CLIENT_ID=<your-client-id>
OIDC_CUSTOM_DOMAIN=https://auth.test.login-connexion.alpha.canada.ca
OIDC_CLIENT_SECRET=<your-client-secret>
# Optional: requested OIDC scopes (space- or comma-delimited).
# Supported values: openid, profile, email, phone, language
# Defaults to openid when omitted.
# OIDC_REQUESTED_SCOPES=openid email language

# Production/staging only: AWS Secrets Manager secret ID for OIDC private key.
# Used for private_key_jwt authentication (replaces client_secret_post).
# Format: <stage>/oidc/private-key
# Leave empty for local development to use client_secret_post instead.
# OIDC_PRIVATE_KEY_SECRET_ID=prod/oidc/private-key
# OIDC_USE_PRIVATE_KEY_JWT=true
